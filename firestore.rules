rules_version = '2';

// VoltDrive Firestore security rules.
//
// The web/mobile client NEVER talks to Firestore directly — every read and
// write goes through the Go backend, which uses a privileged Google service
// identity (IAM) that bypasses these rules. Therefore client-side access is
// denied outright. This prevents anyone from using the public Firebase Web API
// key to read or tamper with subscriptions, the admin list, users, fleets or
// branding straight from the browser.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
